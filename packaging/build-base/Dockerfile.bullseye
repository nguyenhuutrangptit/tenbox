# TenBox release build base image (bullseye edition).
#
# Pinned to Debian 11 ("bullseye") because that is the lowest glibc version
# (2.31) tenbox supports. Building on a newer base would silently raise the
# supported floor; building on an older base brings C++20 toolchain headaches
# that are not worth solving. glibc symbols are forward-compatible, so
# binaries linked here run on Debian 11/12/13, Ubuntu 20.04/22.04/24.04,
# Raspberry Pi OS 11+, Armbian Bullseye+, and any other Debian-derived
# distro with libc6 >= 2.31.
#
# Compared to the previous Dockerfile.jammy this image also static-links
# libssl/libcrypto (OpenSSL 3) and -static-libstdc++/-static-libgcc into
# the final binaries, so the deb's only runtime deps are libc6 and
# ca-certificates. That removes the libssl3 vs libssl3t64 OR-dep dance
# and lets the same deb install on bullseye (libssl1.1 only) without any
# packaging gymnastics.
#
# This image only carries the static dependencies and a build environment;
# the actual tenbox sources are bind-mounted in by the release workflow.
FROM debian:11

ARG DEBIAN_FRONTEND=noninteractive

# bullseye ships GCC 10. Earlier drafts pulled GCC 12 from
# bullseye-backports for fuller C++20 support, but bullseye is now
# oldstable and archive.debian.org has dropped gcc-12 from the
# backports pool. Surveying tenbox's source tree showed it doesn't
# actually use the C++20 features GCC 10 lacks (no <ranges>, no
# header <concepts>, no <format>, no <source_location>, no
# coroutines), so stock GCC 10 + `-std=c++20` is sufficient. If a
# new dependency starts requiring GCC 11+ features the cleanest
# next step is to compile a recent GCC from source inside this
# image, not to chase moving bullseye archives.
#
# CMake comes from kitware's apt repo because bullseye's 3.18 cannot
# parse the single-URL FetchContent_Declare blocks in the top-level
# CMakeLists.txt (the `URL ... DOWNLOAD_EXTRACT_TIMESTAMP TRUE` form
# requires 3.24+).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        gnupg \
        lsb-release \
    && curl -fsSL https://apt.kitware.com/keys/kitware-archive-latest.asc \
        | gpg --dearmor -o /usr/share/keyrings/kitware-archive-keyring.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/kitware-archive-keyring.gpg] https://apt.kitware.com/ubuntu/ focal main" \
        > /etc/apt/sources.list.d/kitware.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        dpkg-dev \
        file \
        git \
        gzip \
        make \
        ninja-build \
        nasm \
        perl \
        pkg-config \
        python3 \
        tar \
        xz-utils \
        yasm \
    && rm -rf /var/lib/apt/lists/*

ENV DEPS_PREFIX=/opt/tenbox-deps
ENV PKG_CONFIG_PATH=$DEPS_PREFIX/lib/pkgconfig
ENV CFLAGS="-O2 -fPIC"
ENV CXXFLAGS="-O2 -fPIC"

# Pin upstream versions so build outputs are reproducible across runs.
ARG X264_REF=stable
ARG OPUS_VERSION=1.5.2
# libyuv: pin to a specific commit on main rather than tracking the
# `stable` branch. The stable branch occasionally ships NEON inline
# assembly that older binutils rejects (e.g. `ld1 {v4.16b}, [x3, 80]`
# without the required `#` on the immediate offset), which breaks the
# arm64 build-base. Pinning a known-good main commit also makes the
# static archive bit-for-bit reproducible across runs.
ARG LIBYUV_REF=b438739c8b08eba2c562a62ea5961f6215d525ed
ARG FFMPEG_VERSION=6.1.1
# nv-codec-headers: header-only stubs for the NVENC/NVDEC SDK. FFmpeg
# uses dlopen at runtime to load the actual NVIDIA driver libraries
# (libnvidia-encode.so.1), so no GPU or CUDA toolkit is needed at build
# time — only these headers.
# Pin to the SDK 11.1 line: FFmpeg 6.1.x's nvenc.c uses the _PL buffer
# format names (NV_ENC_BUFFER_FORMAT_NV12_PL etc.) which were removed in
# SDK 12.0. Using 12.x headers here causes compile errors against FFmpeg
# 6.1.1. If FFmpeg is ever bumped to 7.x this can be updated to 12.x.
ARG NV_CODEC_HEADERS_VERSION=11.1.5.3
ARG CURL_VERSION=8.10.1
# OpenSSL 3.0 is the LTS line (security support through 2026-09).
# Static-linking it means the deb no longer needs libssl3/libssl3t64 in
# Depends, which is the whole reason this base image exists: bullseye
# only ships libssl1.1, and we want one deb to install on every supported
# distro.
ARG OPENSSL_VERSION=3.0.15

WORKDIR /tmp/build

# OpenSSL (Apache-2.0): static libssl + libcrypto used by tenboxd's cloud
# tunnel (cloud_tunnel.cpp) and transitively by libdatachannel's
# usrsctp/libsrtp. Build first so the rest of the static deps (libcurl,
# anything else needing TLS) pick up this prefix instead of the system
# /usr/include/openssl. `no-shared` produces only the .a archives;
# `no-module` removes the dynamic engine loader (we don't use engines);
# `no-tests` skips ~30s of test compilation that we don't need.
#
# Architecture target is auto-derived: openssl's Configure script reads
# `uname -m` when no explicit target is given, which produces
# `linux-x86_64` on amd64 runners and `linux-aarch64` on arm64 runners.
RUN curl -fsSL "https://www.openssl.org/source/openssl-${OPENSSL_VERSION}.tar.gz" \
        | tar xz \
    && cd openssl-${OPENSSL_VERSION} \
    && ./Configure \
        --prefix=$DEPS_PREFIX \
        --openssldir=/etc/ssl \
        --libdir=lib \
        no-shared no-module no-tests \
    && make -j"$(nproc)" \
    && make install_sw \
    && cd .. && rm -rf openssl-${OPENSSL_VERSION}

# x264 (GPL): static encoder for libavcodec to wrap. tenbox is GPLv3 so
# the static link is fine; switching to OpenH264 only makes sense if the
# project relicenses, which is explicitly not in scope.
RUN git clone --depth 1 --branch ${X264_REF} https://code.videolan.org/videolan/x264.git \
    && cd x264 \
    && ./configure --prefix=$DEPS_PREFIX --enable-static --enable-pic --disable-cli \
    && make -j"$(nproc)" \
    && make install \
    && cd .. && rm -rf x264

# opus (BSD): static encoder + decoder for the Opus audio path.
RUN curl -fsSL "https://downloads.xiph.org/releases/opus/opus-${OPUS_VERSION}.tar.gz" \
        | tar xz \
    && cd opus-${OPUS_VERSION} \
    && ./configure --prefix=$DEPS_PREFIX --enable-static --disable-shared --with-pic \
    && make -j"$(nproc)" \
    && make install \
    && cd .. && rm -rf opus-${OPUS_VERSION}

# libyuv (BSD): tenbox's BGRA -> YUV fast path. Upstream uses gn/ninja or
# cmake; we go through cmake for portability and to keep the static .a in
# the same prefix.
#
# CMAKE_POLICY_VERSION_MINIMUM=3.5 is required because libyuv's
# cmake_minimum_required is older than what cmake 4 will accept by
# default. The flag tells cmake "treat this project as if it asked for
# at least 3.5 policy semantics" without us having to fork upstream.
RUN git clone https://chromium.googlesource.com/libyuv/libyuv \
    && git -C libyuv checkout ${LIBYUV_REF} \
    && cmake -S libyuv -B libyuv/build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=$DEPS_PREFIX \
        -DBUILD_SHARED_LIBS=OFF \
        -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
        -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    && cmake --build libyuv/build --target install \
    && rm -rf libyuv

# nv-codec-headers (MIT): header-only NVENC/NVDEC SDK stubs. Install
# before FFmpeg so ./configure detects ffnvcodec and enables h264_nvenc.
# FFmpeg dlopen()s libnvidia-encode.so.1 at runtime; no GPU or CUDA
# toolkit is required here in the build container.
RUN curl -fsSL "https://github.com/FFmpeg/nv-codec-headers/releases/download/n${NV_CODEC_HEADERS_VERSION}/nv-codec-headers-${NV_CODEC_HEADERS_VERSION}.tar.gz" \
        | tar xz \
    && cd nv-codec-headers-${NV_CODEC_HEADERS_VERSION} \
    && make install PREFIX=$DEPS_PREFIX \
    && cd .. && rm -rf nv-codec-headers-${NV_CODEC_HEADERS_VERSION}

# FFmpeg: only the codecs tenbox actually uses (libx264 encode, h264
# decode, libopus encode/decode, h264_nvenc hardware encode).
# h264_nvenc is compiled in via ffnvcodec (header-only at build time);
# the actual libnvidia-encode.so.1 is dlopen'd at runtime on hosts that
# have an NVIDIA driver installed. On hosts without a GPU the codec is
# silently unavailable and tenboxd falls back to libx264.
RUN curl -fsSL "https://ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.xz" \
        | tar xJ \
    && cd ffmpeg-${FFMPEG_VERSION} \
    && ./configure \
        --prefix=$DEPS_PREFIX \
        --pkg-config-flags=--static \
        --extra-cflags="-fPIC -I$DEPS_PREFIX/include" \
        --extra-ldflags="-L$DEPS_PREFIX/lib" \
        --enable-static --disable-shared --enable-pic \
        --disable-everything \
        --disable-doc --disable-programs \
        --disable-network --disable-iconv --disable-bzlib --disable-lzma \
        --disable-xlib --disable-vaapi --disable-vdpau \
        --enable-protocol=file --enable-protocol=pipe \
        --enable-muxer=null --enable-demuxer=null \
        --enable-encoder=libx264 --enable-decoder=h264 \
        --enable-encoder=libopus --enable-decoder=opus \
        --enable-encoder=h264_nvenc \
        --enable-libx264 --enable-libopus \
        --enable-ffnvcodec \
        --enable-gpl \
    && make -j"$(nproc)" \
    && make install \
    && cd .. && rm -rf ffmpeg-${FFMPEG_VERSION}

# libcurl (MIT-style): tenboxd uses it only for the in-process LLM
# proxy (llm_proxy.cpp) which forwards OpenAI-compatible JSON + SSE.
# Built --with-openssl=$DEPS_PREFIX so it picks up our static OpenSSL
# rather than the system libssl1.1 (which is what bullseye otherwise
# ships and would cause a link mix). Disabling every protocol /
# codec / auth scheme tenbox doesn't use keeps the static .a small
# (~700 KB) and shrinks the attack surface — fewer features =
# fewer CVEs we have to chase via tenbox releases.
RUN curl -fsSL "https://curl.se/download/curl-${CURL_VERSION}.tar.xz" \
        | tar xJ \
    && cd curl-${CURL_VERSION} \
    && PKG_CONFIG_PATH=$DEPS_PREFIX/lib/pkgconfig ./configure \
        --prefix=$DEPS_PREFIX \
        --enable-static --disable-shared \
        --with-pic \
        --with-openssl=$DEPS_PREFIX \
        --without-libpsl --without-zstd --without-brotli \
        --without-libidn2 --without-librtmp --without-nghttp2 \
        --without-libssh2 --without-libssh --without-zlib \
        --disable-ldap --disable-ldaps --disable-rtsp --disable-dict \
        --disable-telnet --disable-tftp --disable-pop3 --disable-imap \
        --disable-smb --disable-smtp --disable-gopher --disable-mqtt \
        --disable-ftp --disable-file --disable-manual --disable-docs \
        --disable-ntlm --disable-ntlm-wb --disable-tls-srp \
        --disable-unix-sockets --disable-cookies --disable-progress-meter \
    && make -j"$(nproc)" \
    && make install \
    && cd .. && rm -rf curl-${CURL_VERSION}

# Sanity check: every static archive we ship must actually exist.
# libssl.a / libcrypto.a are new vs Dockerfile.jammy and gate the
# whole "deb installs on bullseye without libssl3" promise.
RUN test -f $DEPS_PREFIX/lib/libavcodec.a \
    && test -f $DEPS_PREFIX/lib/libavformat.a \
    && test -f $DEPS_PREFIX/lib/libavutil.a \
    && test -f $DEPS_PREFIX/lib/libswresample.a \
    && test -f $DEPS_PREFIX/lib/libx264.a \
    && test -f $DEPS_PREFIX/lib/libopus.a \
    && test -f $DEPS_PREFIX/lib/libyuv.a \
    && test -f $DEPS_PREFIX/lib/libcurl.a \
    && test -f $DEPS_PREFIX/lib/libssl.a \
    && test -f $DEPS_PREFIX/lib/libcrypto.a

WORKDIR /src
